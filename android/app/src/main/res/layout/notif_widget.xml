<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="10dp" android:background="#CC1E1E2E">
    <TextView android:id="@+id/notif_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#CDD6F4" android:textSize="14sp" android:textStyle="bold" android:paddingBottom="4dp" android:text="Notifications"/>
    <LinearLayout android:id="@+id/row1" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="3dp" android:visibility="gone">
        <ImageView android:id="@+id/icon1" android:layout_width="24dp" android:layout_height="24dp" android:scaleType="fitCenter" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/text1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="12sp" android:maxLines="3"/>
    </LinearLayout>
    <View android:id="@+id/div1" android:layout_width="match_parent" android:layout_height="1dp" android:background="#44FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="3dp" android:paddingBottom="3dp" android:visibility="gone">
        <ImageView android:id="@+id/icon2" android:layout_width="24dp" android:layout_height="24dp" android:scaleType="fitCenter" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/text2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="12sp" android:maxLines="3"/>
    </LinearLayout>
    <View android:id="@+id/div2" android:layout_width="match_parent" android:layout_height="1dp" android:background="#44FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row3" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="3dp" android:paddingBottom="3dp" android:visibility="gone">
        <ImageView android:id="@+id/icon3" android:layout_width="24dp" android:layout_height="24dp" android:scaleType="fitCenter" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/text3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="12sp" android:maxLines="3"/>
    </LinearLayout>
    <View android:id="@+id/div3" android:layout_width="match_parent" android:layout_height="1dp" android:background="#44FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row4" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="3dp" android:paddingBottom="3dp" android:visibility="gone">
        <ImageView android:id="@+id/icon4" android:layout_width="24dp" android:layout_height="24dp" android:scaleType="fitCenter" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/text4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="12sp" android:maxLines="3"/>
    </LinearLayout>
    <View android:id="@+id/div4" android:layout_width="match_parent" android:layout_height="1dp" android:background="#44FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row5" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="3dp" android:visibility="gone">
        <ImageView android:id="@+id/icon5" android:layout_width="24dp" android:layout_height="24dp" android:scaleType="fitCenter" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/text5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="12sp" android:maxLines="3"/>
    </LinearLayout>
</LinearLayout>
